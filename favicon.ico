<style>
/* ── INDEX EXTRA STYLES ── */
.index-features {
  background: var(--white);
  padding: 56px 48px;
}
.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 28px;
  max-width: 1100px;
  margin: 32px auto 0;
}
.feature-card {
  padding: 28px 24px;
  border: 1px solid var(--gray-100);
  border-radius: var(--radius-lg);
  transition: border-color .2s, box-shadow .2s;
}
.feature-card:hover {
  border-color: var(--gold);
  box-shadow: 0 4px 20px rgba(26,45,79,.07);
}
.feature-icon {
  font-size: 28px;
  margin-bottom: 14px;
}
.feature-title {
  font-family: var(--font-serif);
  font-size: 17px;
  font-weight: 500;
  color: var(--navy);
  margin-bottom: 8px;
}
.feature-desc {
  font-size: 12px;
  color: var(--gray-500);
  line-height: 1.7;
}

/* Regiones activas */
.regiones-section {
  background: var(--cream);
  padding: 56px 48px;
}
.regiones-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 20px;
  margin-top: 32px;
  max-width: 1100px;
  margin: 32px auto 0;
}
.region-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  border: 1px solid var(--gray-100);
  transition: all .2s;
  display: flex;
  flex-direction: column;
}
.region-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(26,45,79,.1);
  border-color: var(--gold-light);
}
.region-card-top {
  background: var(--navy);
  padding: 24px 20px;
  position: relative;
  overflow: hidden;
}
.region-card-top::after {
  content: '';
  position: absolute;
  right: -20px;
  top: -20px;
  width: 80px;
  height: 80px;
  border: 1px solid rgba(201,168,76,.2);
  border-radius: 50%;
}
.region-card-num {
  font-family: var(--font-serif);
  font-size: 36px;
  color: var(--gold);
  line-height: 1;
}
.region-card-label {
  font-size: 10px;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--gray-300);
  margin-top: 4px;
}
.region-card-body {
  padding: 18px 20px;
  flex: 1;
}
.region-card-name {
  font-family: var(--font-serif);
  font-size: 18px;
  font-weight: 400;
  color: var(--navy);
  margin-bottom: 6px;
}
.region-card-provs {
  font-size: 11px;
  color: var(--gray-500);
  line-height: 1.6;
}
.region-card-cta {
  padding: 12px 20px;
  border-top: 1px solid var(--gray-100);
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 500;
}

@media(max-width:768px){
  .index-features,.regiones-section{ padding: 36px 20px; }
}
</style>

